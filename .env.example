# Supabase project
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Expo requires the EXPO_PUBLIC_ prefix for values exposed to the app bundle.
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only values. Do not expose these to browser or mobile bundles.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres
STUDIO_AUDIO_BUCKET=tour-audio

# Creator Studio local publishing uses the seeded demo creator by default.
STUDIO_DEMO_CREATOR_ID=00000000-0000-0000-0000-000000000101
